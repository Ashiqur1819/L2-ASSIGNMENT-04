model Availability {
    id String @id @default(uuid())
    technicianId String
    technicianProfile TechnicianProfile @relation(fields: [technicianId], references: [id])
    day Day
    startTime String
    endTime String
    isAvailable Boolean @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("availabilities")
}